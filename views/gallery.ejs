                            <img src="/images/gallery/image_05_s.jpg" alt="Image 05" />
                        </a>
                        <a href="#" class="more float_r">Detail</a>
                    </div>

                    <div class="gallery_box third">
                        <h3>Fusce tincidunt libero</h3>
                        <a class="lightbox" href="/images/gallery/image_06_l.jpg"
                            title="Morbi tempor vehicula orci, ut pulvinar nisl venenatis eu.">
