                            <img src="/images/gallery/image_01_s.jpg" alt="Image 01" />
                        </a>
                        <a href="#" class="more float_r">Detail</a>
                    </div>

                    <div class="gallery_box">
                        <h3>Pellentesque rhoncus</h3>
                        <a class="lightbox" href="/images/gallery/image_02_l.jpg"
                            title="Maecenas eget ligula et sapien tempus aliquet.">
                            <img src="/images/gallery/image_02_s.jpg" alt="Image 02" />
                        </a>
                        <a href="#" class="more float_r">Detail</a>
                    </div>

                    <div class="gallery_box third">
                        <h3>Nullam faucibus diam</h3>
                        <a class="lightbox" href="/images/gallery/image_03_l.jpg"
                            title="Curabitur id felis justo, quis dapibus turpis.">
                            <img src="/images/gallery/image_03_s.jpg" alt="Image 03" />
                        </a>
                        <a href="#" class="more float_r">Detail</a>
                    </div>

                    <div class="gallery_box">
                        <h3>Integer sit amet</h3>
                        <a class="lightbox" href="/images/gallery/image_04_l.jpg"
                            title="Praesent ac felis et dui dictum tincidunt.">
                            <img src="/images/gallery/image_04_s.jpg" alt="Image 04" />
                        </a>
